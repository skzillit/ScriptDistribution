<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/scriptListFragment">

    <fragment
        android:id="@+id/scriptListFragment"
        android:name="com.zillit.scriptdistribution.ui.scripts.list.ScriptListFragment"
        android:label="Scripts"
        tools:layout="@layout/fragment_script_list">
        <action
            android:id="@+id/action_list_to_detail"
            app:destination="@id/scriptDetailFragment" />
        <action
            android:id="@+id/action_list_to_upload"
            app:destination="@id/uploadScriptFragment" />
    </fragment>

    <fragment
        android:id="@+id/scriptDetailFragment"
        android:name="com.zillit.scriptdistribution.ui.scripts.detail.ScriptDetailFragment"
        android:label="Script Detail"
        tools:layout="@layout/fragment_script_detail">
        <argument
            android:name="scriptId"
            app:argType="string" />
        <action
            android:id="@+id/action_detail_to_breakdown"
            app:destination="@id/breakdownFragment" />
        <action
            android:id="@+id/action_detail_to_analytics"
            app:destination="@id/analyticsFragment" />
    </fragment>

    <fragment
        android:id="@+id/uploadScriptFragment"
        android:name="com.zillit.scriptdistribution.ui.scripts.upload.UploadScriptFragment"
        android:label="Upload Script"
        tools:layout="@layout/fragment_upload_script" />

    <fragment
        android:id="@+id/breakdownFragment"
        android:name="com.zillit.scriptdistribution.ui.breakdown.BreakdownFragment"
        android:label="Breakdown"
        tools:layout="@layout/fragment_breakdown">
        <argument
            android:name="versionId"
            app:argType="string" />
        <argument
            android:name="scriptId"
            app:argType="string" />
    </fragment>

    <fragment
        android:id="@+id/analyticsFragment"
        android:name="com.zillit.scriptdistribution.ui.analytics.AnalyticsFragment"
        android:label="Analytics"
        tools:layout="@layout/fragment_analytics">
        <argument
            android:name="scriptId"
            app:argType="string"
            android:defaultValue="" />
    </fragment>

    <fragment
        android:id="@+id/sidesFragment"
        android:name="com.zillit.scriptdistribution.ui.sides.SidesFragment"
        android:label="Sides"
        tools:layout="@layout/fragment_sides" />

</navigation>
