PORT=3000
MONGODB_URI=mongodb://localhost:27017/script-distribution

# Zillit Auth Encryption Keys
ENCRYPTION_KEY=your_32_char_aes_encryption_key_here
IV_KEY=your_16_char_iv_key_here
